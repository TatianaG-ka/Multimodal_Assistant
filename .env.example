# --- App mode -----------------------------------------------------------
# offline = skip LLM calls, use heuristics + cached similar-item prices.
# online  = use LLM providers defined below.
APP_MODE=offline

# --- LLM providers ------------------------------------------------------
LLM_PROVIDER=openai          # openai | deepseek
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# Optional per-agent overrides (default to APP_MODE)
SCANNER_USE_LLM=
FRONTIER_USE_LLM=

# --- Storage ------------------------------------------------------------
PERSIST_DIRECTORY=/tmp/chroma
VECTORSTORE_NAME=products
VECTORSTORE_PATH=/tmp/chroma

# --- Alerting -----------------------------------------------------------
# Toggle channels (both default off - no messages are sent unless enabled)
DO_PUSH=false
DO_TEXT=false

# Pushover (https://pushover.net) - only required when DO_PUSH=true
PUSHOVER_USER=
PUSHOVER_TOKEN=

# Twilio SMS - only required when DO_TEXT=true
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
MY_PHONE_NUMBER=

# --- Alert threshold / logging -----------------------------------------
# Minimum dollar discount that triggers an alert. Set to 0 for "any margin".
DEAL_THRESHOLD=50
LOG_LEVEL=INFO
